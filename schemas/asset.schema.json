{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Asset Metadata Schema",
  "type": "object",
  "required": [
    "id",
    "title",
    "slug",
    "category",
    "subcategory",
    "type",
    "format",
    "status",
    "version",
    "description",
    "visual_style",
    "semantic_role",
    "tags",
    "dominant_colors",
    "use_cases",
    "animation_ideas",
    "files"
  ],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "slug": { "type": "string" },
    "category": { "type": "string" },
    "subcategory": { "type": "string" },
    "type": { "type": "string" },
    "format": { "type": "string" },
    "status": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "visual_style": {
      "type": "object",
      "required": ["medium", "line_style", "shading", "background", "perspective"],
      "properties": {
        "medium": { "type": "string" },
        "line_style": { "type": "string" },
        "shading": { "type": "string" },
        "background": { "type": "string" },
        "perspective": { "type": "string" }
      }
    },
    "semantic_role": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dominant_colors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "use_cases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "animation_ideas": {
      "type": "array",
      "items": { "type": "string" }
    },
    "files": {
      "type": "object",
      "required": ["image", "metadata", "prompt"],
      "properties": {
        "image": { "type": "string" },
        "metadata": { "type": "string" },
        "prompt": { "type": "string" }
      }
    }
  }
}
